; User identity & signing settings

[user]
	name = Clay Miller
	email = clay@smockle.com
	signingkey = 1E6BEB6FED57655B

[commit]
	gpgsign = true

[log]
	showSignature = true

; Repo & remote settings

[url "https://github.com/"]
	insteadOf = git@github.com:

[init]
	defaultBranch = main

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

; Pushing & pulling settings

[pull]
	rebase = true

[rebase]
	autoStash = true
	updateRefs = true

[push]
	default = current
	autoSetupRemote = true

[fetch]
	prune = true

; Other settings

[help]
	autocorrect = immediate
